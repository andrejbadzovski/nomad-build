# ── Sanity CMS ──────────────────────────────────────────
# 1. Go to https://sanity.io and create a free project
# 2. Copy your Project ID from the project dashboard
# 3. Add this file as .env.local (never commit .env.local)

NEXT_PUBLIC_SANITY_PROJECT_ID=isd947mz
NEXT_PUBLIC_SANITY_DATASET=production

# Read token — needed for draft previews (optional for now)
# Get from sanity.io → your project → API → Tokens
SANITY_API_READ_TOKEN=

# ── Deployment on Vercel ────────────────────────────────
# Add all NEXT_PUBLIC_* vars in Vercel → Project → Settings → Environment Variables
# Then redeploy. The /studio route will also work on Vercel.
